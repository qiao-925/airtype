#!/usr/bin/env python3
"""airtype — 极简语音输入法. 快捷键 → 录音 → STT → 输入."""

import os, re, sys, time, signal, shutil, argparse, subprocess
from pathlib import Path

DIR = Path.home() / '.local' / 'share' / 'airtype'
# 支持 AIRTYPE_CONFIG 环境变量覆盖配置文件路径（用于测试）
CONFIG = Path(os.environ.get('AIRTYPE_CONFIG', str(DIR / 'config')))
LOG = DIR / 'airtype.log'
LOCK = Path('/tmp/airtype.lock')
PIDFILE = Path('/tmp/airtype-overlay.pid')
STARTFILE = Path('/tmp/airtype-start-time')

# ========== ASR 语音识别引擎配置 ==========
# ASR_ENGINE: 语音识别引擎，可选值：
#   "sensevoice" — SenseVoice.cpp（默认，速度最快，延迟最低）
#   "qwen3asr"   — transcribe.cpp + Qwen3-ASR（准确率更高，52语言）
#   "funasr"     — llama-funasr-cli + Fun-ASR-Nano（方言支持好）
ASR_ENGINE = 'sensevoice'

# MODEL: ASR 模型文件名，需与 ASR_ENGINE 匹配
MODEL = 'sense-voice-small-q5_k.gguf'

MAX_SECONDS = 3600
LANG = 'zh'
THREADS = 4

# ========== 后处理润色模型配置 ==========
# REFINE_MODEL: 后处理模型文件名，为空则跳过后处理
# 可选值：
#   "Qwen3.5-0.8B-Q4_K_M.gguf" — 轻量，延迟低（推荐）
#   "Qwen3.5-2B-Q4_K_M.gguf"   — 更强，延迟稍高
REFINE_MODEL = ''
REFINE_PROMPT = '''你是语音输入后处理助手。对用户语音识别的原始文本做如下处理：
1. 去除填充词和语气词（嗯、啊、那个、就是说、你知道的、然后、对吧）
2. 去除重复词句（如"今天今天天气不错"→"今天天气不错"）
3. 识别自我纠正（如"明天，不对，后天"→"后天"），只保留最终意图
4. 修正明显的识别错误，补全标点符号
5. 如有列表或步骤，整理为结构化文本
6. 保持原意，语言简洁自然，不要添加原文没有的内容
只输出修正后的文本，不要解释。'''
REFINE_THREADS = 4


# 合法的 ASR 引擎列表，用于配置校验
_VALID_ASR_ENGINES = ('sensevoice', 'qwen3asr', 'funasr')


def load_config():
    """从 config 文件加载配置。config 格式为 KEY=VALUE，支持引号和注释。"""
    global ASR_ENGINE, MODEL, MAX_SECONDS, LANG, THREADS
    global REFINE_MODEL, REFINE_PROMPT, REFINE_THREADS
    if not CONFIG.is_file():
        return
    try:
        for line in CONFIG.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            if '=' in line:
                k, v = line.split('=', 1)
                k, v = k.strip(), v.strip().strip('"').strip("'")
                if k == 'ASR_ENGINE':
                    if v in _VALID_ASR_ENGINES:
                        ASR_ENGINE = v
                    else:
                        log(f'! 未知的 ASR_ENGINE: {v}，使用默认值: {ASR_ENGINE}')
                elif k == 'MODEL':         MODEL = v
                elif k == 'MAX_SECONDS':   MAX_SECONDS = int(v)
                elif k == 'LANG':          LANG = v
                elif k == 'THREADS':       THREADS = int(v)
                elif k == 'REFINE_MODEL':  REFINE_MODEL = v
                elif k == 'REFINE_PROMPT': REFINE_PROMPT = v
                elif k == 'REFINE_THREADS': REFINE_THREADS = int(v)
    except Exception as e:
        log(f'! 配置解析错误: {e}')


def log(msg):
    ts = time.strftime('%Y-%m-%d %H:%M:%S')
    try:
        LOG.parent.mkdir(parents=True, exist_ok=True)
        with open(LOG, 'a') as f:
            f.write(f'{ts} {os.getpid()} {msg}\n')
    except Exception:
        pass


def kill_overlay():
    killed = False
    if PIDFILE.is_file():
        try:
            pid = int(PIDFILE.read_text().strip())
            os.kill(pid, signal.SIGTERM)
            killed = True
        except (ProcessLookupError, ValueError):
            pass
        PIDFILE.unlink(missing_ok=True)
    if killed:
        time.sleep(0.3)


def show_overlay(phase):
    overlay = DIR / 'voice-overlay'
    if not os.access(overlay, os.X_OK):
        return
    kill_overlay()
    p = subprocess.Popen([str(overlay), phase])
    PIDFILE.write_text(str(p.pid))


def show_error(msg):
    """Show error overlay and log the error."""
    log(f'! ERROR: {msg}')
    overlay = DIR / 'voice-overlay'
    if os.access(overlay, os.X_OK):
        if len(msg) > 40:
            msg = msg[:37] + '...'
        kill_overlay()
        show_overlay(f'error:{msg}')
        time.sleep(3)
    kill_overlay()


def copy_to_clipboard(text):
    """Copy text to clipboard. Wayland uses wl-copy, X11 uses xclip."""
    tools = [
        (['wl-copy'], {}),
        (['xclip', '-selection', 'clipboard'], {}),
        (['xsel', '--clipboard', '--input'], {}),
    ]
    for cmd, _ in tools:
        if shutil.which(cmd[0]):
            r = subprocess.run(cmd, input=text.encode(), check=False)
            return r.returncode == 0
    return False


_cleaned_up = False
_audio = None

def cleanup():
    global _cleaned_up
    if _cleaned_up:
        return
    _cleaned_up = True
    # 防止 cleanup 期间收到第二个 SIGTERM 跳过后续清理
    prev_term = signal.signal(signal.SIGTERM, signal.SIG_IGN)
    prev_hup = signal.signal(signal.SIGHUP, signal.SIG_IGN)
    try:
        kill_overlay()
        if _audio and _audio.is_file():
            _audio.unlink(missing_ok=True)
        for f in (LOCK, STARTFILE):
            f.unlink(missing_ok=True)
    finally:
        signal.signal(signal.SIGTERM, prev_term)
        signal.signal(signal.SIGHUP, prev_hup)


def parse_output(raw):
    lines = []
    for line in raw.splitlines():
        line = re.sub(r'^\[[\d.]+-[\d.]+\]\s*', '', line)
        line = re.sub(r'<\|[^|]*\|>', '', line)
        line = line.strip()
        if line:
            lines.append(line)
    text = ' '.join(lines)
    # 清理可能导致浏览器跳转或输入异常的控制字符
    text = re.sub(r'[\x00-\x08\x0b\x0c\x0e-\x1f\x7f]', '', text)  # 保留 \t \n \r，后面单独处理
    text = text.replace('\n', ' ').replace('\r', '').replace('\t', ' ')
    return re.sub(r' +', ' ', text).strip()


def run_asr(audio_path):
    """
    ASR 策略函数：根据 ASR_ENGINE 配置选择对应的 runtime 执行语音识别。
    返回识别出的原始文本，失败返回空字符串。

    支持的引擎：
    - sensevoice: SenseVoice.cpp（默认，速度快）
    - qwen3asr:   transcribe.cpp + Qwen3-ASR（准确率高）
    - funasr:     llama-funasr-cli + Fun-ASR-Nano（方言好）
    """
    model_path = DIR / 'models' / MODEL

    # 统一检查：模型文件是否存在
    if not model_path.is_file():
        log(f'! 模型文件不存在: {model_path}')
        return ''

    if ASR_ENGINE == 'sensevoice':
        # --- SenseVoice.cpp: 非自回归，速度最快 ---
        engine = DIR / 'SenseVoice.cpp' / 'build' / 'bin' / 'sense-voice-main'
        if not engine.is_file():
            log(f'! SenseVoice 引擎不存在: {engine}')
            return ''
        cmd = [str(engine), '-m', str(model_path), '-l', LANG,
               '--use-itn', '-t', str(THREADS), str(audio_path)]

    elif ASR_ENGINE == 'qwen3asr':
        # --- transcribe.cpp: 自回归，准确率更高 ---
        engine = DIR / 'transcribe.cpp' / 'build' / 'bin' / 'transcribe'
        if not engine.is_file():
            log(f'! transcribe.cpp 引擎不存在: {engine}')
            return ''
        cmd = [str(engine), '-m', str(model_path),
               '-t', str(THREADS), str(audio_path)]

    elif ASR_ENGINE == 'funasr':
        # --- llama-funasr-cli: Fun-ASR-Nano 官方 runtime ---
        engine = DIR / 'Fun-ASR' / 'runtime' / 'llama.cpp' / 'build' / 'bin' / 'llama-funasr-cli'
        enc_model = DIR / 'models' / 'funasr-encoder-f16.gguf'
        if not engine.is_file():
            log(f'! FunASR 引擎不存在: {engine}')
            return ''
        if not enc_model.is_file():
            log(f'! FunASR encoder 不存在: {enc_model}')
            return ''
        cmd = [str(engine), '--enc', str(enc_model), '-m', str(model_path),
               '-t', str(THREADS), '-a', str(audio_path)]

    else:
        log(f'! 未知的 ASR 引擎: {ASR_ENGINE}')
        return ''

    r = subprocess.run(cmd, capture_output=True, text=True, check=False)

    # 记录 stderr 以便调试（不阻塞主流程）
    if r.returncode != 0 and r.stderr:
        log(f'! ASR 错误 ({ASR_ENGINE}): {r.stderr[:200]}')

    return r.stdout.strip() if r.stdout else ''


def run_refine(text):
    """调用 llama-cli 后处理润色."""
    llama = DIR / 'llama.cpp' / 'build' / 'bin' / 'llama-cli'
    model = DIR / 'models' / REFINE_MODEL

    # 检查引擎和模型是否存在
    if not llama.is_file():
        log(f'! 后处理引擎不存在: {llama}')
        return None
    if not model.is_file():
        log(f'! 后处理模型不存在: {model}')
        return None

    log(f'后处理开始 (模型: {REFINE_MODEL})')
    prompt = f'{REFINE_PROMPT}\n\n{text}'
    try:
        r = subprocess.run(
            [str(llama), '-m', str(model), '-p', prompt,
             '-n', '512', '-t', str(REFINE_THREADS),
             '--no-display-prompt', '--log-disable'],
            capture_output=True, text=True, check=False, timeout=60)
    except subprocess.TimeoutExpired:
        log('! 后处理超时 (60s)，跳过')
        return None

    # 记录 stderr 以便调试
    if r.returncode != 0 and r.stderr:
        log(f'! 后处理错误: {r.stderr[:200]}')

    out = r.stdout.strip() if r.stdout else ''
    if not out:
        log('! 后处理输出为空')
        return None

    log(f'后处理完成: {out[:100]}')
    return out


def main():
    global MODEL, MAX_SECONDS, LANG, THREADS

    load_config()

    p = argparse.ArgumentParser(description='airtype — voice to text, anywhere')
    p.add_argument('--lang', default=LANG, help='语言代码')
    p.add_argument('--model', default=MODEL, help='GGUF 模型文件名')
    p.add_argument('--max-s', type=int, default=MAX_SECONDS, help='最大录音秒数')
    p.add_argument('--threads', type=int, default=THREADS, help='推理线程数')
    p.add_argument('--clipboard', action='store_true',
                   help='复制到剪贴板而非直接输入')
    args = p.parse_args()

    MODEL = args.model
    MAX_SECONDS = args.max_s
    LANG = args.lang
    THREADS = args.threads

    log('--- 启动 ---')

    # --- 二次按键: 终止当前录音 ---
    if LOCK.is_file():
        try:
            pid = int(LOCK.read_text().strip())
            try:
                os.kill(pid, 0)
                log(f'二次按键: 终止录音 PID={pid}')
                subprocess.run(['pkill', '-f', 'rec.*airtype-input'],
                               capture_output=True)
                kill_overlay()
                sys.exit(0)
            except (ProcessLookupError, PermissionError):
                log(f'残留锁清除 PID={pid}')
                LOCK.unlink()
        except (ValueError, FileNotFoundError):
            LOCK.unlink(missing_ok=True)

    # --- 首次按键: 原子创建锁 ---
    try:
        fd = os.open(str(LOCK), os.O_CREAT | os.O_EXCL | os.O_WRONLY, 0o600)
        os.write(fd, str(os.getpid()).encode())
        os.close(fd)
    except FileExistsError:
        log('锁竞争失败，退出')
        sys.exit(0)
    log(f'写锁 PID={os.getpid()}')

    # --- 环境检查：根据 ASR 引擎检查对应的 runtime 是否就绪 ---
    model_path = DIR / 'models' / MODEL

    checks = [
        (model_path.is_file(), f'Model not found: {MODEL}'),
        (shutil.which('rec') is not None, 'sox (rec) not installed'),
    ]

    # 检查对应引擎的 runtime 二进制
    if ASR_ENGINE == 'sensevoice':
        engine_bin = DIR / 'SenseVoice.cpp' / 'build' / 'bin' / 'sense-voice-main'
        checks.insert(0, (engine_bin.is_file(), 'SenseVoice engine not found'))
    elif ASR_ENGINE == 'qwen3asr':
        engine_bin = DIR / 'transcribe.cpp' / 'build' / 'bin' / 'transcribe'
        checks.insert(0, (engine_bin.is_file(), 'transcribe.cpp engine not found'))
    elif ASR_ENGINE == 'funasr':
        engine_bin = DIR / 'Fun-ASR' / 'runtime' / 'llama.cpp' / 'build' / 'bin' / 'llama-funasr-cli'
        enc_model = DIR / 'models' / 'funasr-encoder-f16.gguf'
        checks.insert(0, (engine_bin.is_file(), 'FunASR engine not found'))
        checks.insert(1, (enc_model.is_file(), 'FunASR encoder not found'))
    else:
        show_error(f'Unknown ASR engine: {ASR_ENGINE}')
        sys.exit(1)
    if not args.clipboard:
        checks.append((shutil.which('wtype') is not None, 'wtype not installed'))
    else:
        checks.append((any(shutil.which(t) for t in ('wl-copy', 'xclip', 'xsel')),
                        'No clipboard tool (wl-copy/xclip)'))
    for ok, msg in checks:
        if not ok:
            show_error(msg)
            sys.exit(1)

    has_overlay = os.access(DIR / 'voice-overlay', os.X_OK)
    log(f'overlay={1 if has_overlay else 0} asr={ASR_ENGINE} model={MODEL} clipboard={1 if args.clipboard else 0}')

    global _audio
    _audio = Path(f'/tmp/airtype-input-{os.getpid()}.wav')
    audio = _audio

    # --- 录音 ---
    log(f'录音 max={MAX_SECONDS} (再按快捷键终止)')
    # 先启动录音，再显示 overlay，避免音频设备初始化导致前 1-2 秒丢失
    rec_proc = subprocess.Popen(
        ['timeout', str(MAX_SECONDS), 'rec', '-q', '-r', '16000',
         '-c', '1', '-b', '16', str(audio)],
        stderr=subprocess.DEVNULL)
    if has_overlay:
        STARTFILE.write_text(str(int(time.time())))
        show_overlay('listening')

    rec_proc.wait()

    try:
        sz = audio.stat().st_size
    except FileNotFoundError:
        log('录音被取消')
        sys.exit(0)

    if sz < 1600:
        log('音频过短')
        audio.unlink(missing_ok=True)
        sys.exit(0)

    log(f'录音完成 {sz} bytes')

    # --- ASR 语音识别（通过策略函数调用对应引擎） ---
    kill_overlay()
    log(f'开始识别 (引擎: {ASR_ENGINE})')

    raw = run_asr(audio)
    log(f'RAW: {raw[:300]}')

    audio.unlink(missing_ok=True)

    if not raw:
        show_error('Recognition empty')
        sys.exit(0)

    text = parse_output(raw)
    if not text:
        show_error('Parse failed')
        sys.exit(0)

    log(f'识别完成: {text}')

    # --- 后处理润色 ---
    log(f'后处理配置: REFINE_MODEL="{REFINE_MODEL}"')
    if REFINE_MODEL:
        refined = run_refine(text)
        if refined:
            log(f'润色生效: "{text}" → "{refined}"')
            text = refined
        else:
            log(f'润色未生效，使用原始文本')
    else:
        log('后处理未配置，跳过')

    # --- 输出文本 ---
    log(f'最终文本: "{text[:100]}"')

    if args.clipboard:
        log('尝试复制到剪贴板...')
        ok = copy_to_clipboard(text)
        if ok:
            log('已复制到剪贴板')
            if has_overlay:
                kill_overlay()
                show_overlay('clipboard')
                time.sleep(2)
        else:
            show_error('Clipboard copy failed')
    else:
        kill_overlay()
        time.sleep(0.1)  # 等待焦点回到目标窗口
        # 清理文本中可能导致浏览器跳转的控制字符
        text = text.replace('\n', ' ').replace('\r', '').replace('\t', ' ')
        # 用剪贴板 + 模拟粘贴键代替 wtype 直接输入，避免浏览器跳转和输入法冲突
        pasted = False
        # Step 1: 复制到剪贴板
        log('Step 1: 复制到剪贴板...')
        if copy_to_clipboard(text):
            time.sleep(0.05)  # 等待剪贴板就绪
            # Step 2: 模拟 Ctrl+V 粘贴 (通过 wtype 发送快捷键)
            log('Step 2: 模拟 Ctrl+V 粘贴...')
            r = subprocess.run(['wtype', '-M', 'ctrl', 'v', '-m', 'ctrl'], check=False)
            if r.returncode == 0:
                log('已粘贴输入')
                pasted = True
            else:
                log(f'! wtype 粘贴失败: exit={r.returncode}, stderr={r.stderr}')
        else:
            log('! 剪贴板复制失败')
        if not pasted:
            # 回退: 直接用 wtype 输入 (去掉换行符以防万一)
            safe_text = text.replace('\n', ' ').replace('\r', '')
            log(f'回退: 直接 wtype 输入 ({len(safe_text)} 字符)...')
            r = subprocess.run(['wtype', '--', safe_text], check=False)
            if r.returncode != 0:
                log(f'! wtype 失败: exit={r.returncode}, stderr={r.stderr}')
            else:
                log('已输入 (回退模式)')


def _handle_signal(signum, frame):
    sys.exit(0)

if __name__ == '__main__':
    signal.signal(signal.SIGTERM, _handle_signal)
    signal.signal(signal.SIGHUP, _handle_signal)
    signal.signal(signal.SIGINT, _handle_signal)
    try:
        main()
    except KeyboardInterrupt:
        pass
    finally:
        cleanup()
